# Environment Variables Example
# Copy this file to .env.local and fill in your values

# API Configuration
API_BASE_URL=https://api.polypharmacy-manager.com
API_KEY=your_api_key_here

# Consultation Service
CONSULTATION_API_URL=https://consultation.polypharmacy-manager.com

# Drug Database API
DRUG_DATABASE_API_URL=https://drugdb.polypharmacy-manager.com
DRUG_DATABASE_API_KEY=your_drug_db_key_here

# Notification Service
NOTIFICATION_SERVICE_ENABLED=true

# Analytics (Optional)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=your_analytics_key_here

# Feature Flags
ENABLE_DRUG_LOCATOR=true
ENABLE_VIDEO_CONSULTATION=true
ENABLE_VOICE_FEATURES=true

# Development
DEV_MODE=true
LOG_LEVEL=debug
