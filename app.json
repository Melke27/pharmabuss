{
  "expo": {
    "name": "PolyCare",
    "slug": "polycare",
    "scheme": "polycare",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D4FA3"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polycare.ncd"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1D4FA3"
      },
      "package": "com.polycare.ncd"
    },
    "web": {
      "favicon": "./assets/icon.png"
    }
  }
}
